{
  "name": "cityos-commerce",
  "version": "1.0.0",
  "description": "MCP server for CityOS commerce domain — Medusa v2 product catalog, orders, inventory",
  "transport": {
    "type": "sse",
    "url": "http://cityos-bff:4001/api/mcp/commerce"
  },
  "authentication": {
    "type": "bearer",
    "header": "Authorization"
  },
  "tools": [
    {
      "name": "search_products",
      "description": "Search the product catalog by name, category, or keyword",
      "risk_level": "read-only",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": { "type": "string" },
          "category": { "type": "string" },
          "merchant_id": { "type": "string" }
        },
        "required": ["query"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "products": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" },
                "price": { "type": "number" },
                "currency": { "type": "string" },
                "in_stock": { "type": "boolean" },
                "merchant_name": { "type": "string" }
              }
            }
          }
        }
      }
    },
    {
      "name": "check_order_status",
      "description": "Check the status of an order by order ID",
      "risk_level": "read-only",
      "input_schema": {
        "type": "object",
        "properties": {
          "order_id": { "type": "string" }
        },
        "required": ["order_id"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "order_id": { "type": "string" },
          "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
          "items": { "type": "array" },
          "total": { "type": "number" },
          "tracking_number": { "type": "string" }
        }
      }
    },
    {
      "name": "check_inventory",
      "description": "Check inventory levels for a product or merchant",
      "risk_level": "read-only",
      "input_schema": {
        "type": "object",
        "properties": {
          "product_id": { "type": "string" },
          "merchant_id": { "type": "string" }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "product_id": { "type": "string" },
          "quantity_available": { "type": "number" },
          "low_stock_threshold": { "type": "number" },
          "restock_date": { "type": "string" }
        }
      }
    },
    {
      "name": "apply_promotion",
      "description": "Apply a promotional discount code to a cart or order",
      "risk_level": "approval-required",
      "input_schema": {
        "type": "object",
        "properties": {
          "cart_id": { "type": "string" },
          "promo_code": { "type": "string" }
        },
        "required": ["cart_id", "promo_code"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "discount_amount": { "type": "number" },
          "new_total": { "type": "number" },
          "message": { "type": "string" }
        }
      }
    }
  ]
}
