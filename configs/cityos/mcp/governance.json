{
  "name": "cityos-governance",
  "version": "1.0.0",
  "description": "MCP server for CityOS governance domain — permits, licenses, policies, public records",
  "transport": {
    "type": "sse",
    "url": "http://cityos-bff:4002/api/mcp/governance"
  },
  "authentication": {
    "type": "bearer",
    "header": "Authorization"
  },
  "tools": [
    {
      "name": "lookup_permit_status",
      "description": "Look up the status of a building or business permit by permit ID",
      "risk_level": "read-only",
      "input_schema": {
        "type": "object",
        "properties": {
          "permit_id": { "type": "string", "description": "Permit application ID, e.g. APP-2025-0042" }
        },
        "required": ["permit_id"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["pending", "approved", "rejected", "in_review"] },
          "applicant": { "type": "string" },
          "submitted_date": { "type": "string", "format": "date" },
          "reviewer": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    {
      "name": "search_policies",
      "description": "Search city policies, zoning regulations, and public ordinances",
      "risk_level": "read-only",
      "input_schema": {
        "type": "object",
        "properties": {
          "query": { "type": "string", "description": "Search keywords or question" },
          "category": { "type": "string", "enum": ["zoning", "business", "health", "safety", "environment"], "description": "Policy category filter" },
          "language": { "type": "string", "enum": ["en", "ar"], "default": "en" }
        },
        "required": ["query"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "title": { "type": "string" },
                "excerpt": { "type": "string" },
                "url": { "type": "string" },
                "effective_date": { "type": "string" }
              }
            }
          }
        }
      }
    },
    {
      "name": "list_public_records",
      "description": "List public records such as council minutes, budgets, and reports",
      "risk_level": "read-only",
      "input_schema": {
        "type": "object",
        "properties": {
          "record_type": { "type": "string", "enum": ["council_minutes", "budget", "report", "contract"] },
          "date_from": { "type": "string", "format": "date" },
          "date_to": { "type": "string", "format": "date" }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "records": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "title": { "type": "string" },
                "date": { "type": "string" },
                "download_url": { "type": "string" }
              }
            }
          }
        }
      }
    },
    {
      "name": "submit_permit_application",
      "description": "Submit a new permit or license application (requires officer approval)",
      "risk_level": "approval-required",
      "input_schema": {
        "type": "object",
        "properties": {
          "permit_type": { "type": "string", "enum": ["building", "business", "event", "renovation"] },
          "applicant_name": { "type": "string" },
          "applicant_id": { "type": "string" },
          "property_address": { "type": "string" },
          "description": { "type": "string" }
        },
        "required": ["permit_type", "applicant_name", "property_address"]
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "application_id": { "type": "string" },
          "status": { "type": "string" },
          "estimated_review_days": { "type": "number" }
        }
      }
    }
  ]
}
