{
  "info": {
    "name": "CityOSJarvis API",
    "description": "Postman collection for CityOSJarvis BFF AI routes and OpenJarvis endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/bff/ai/health"
          }
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" },
              { "key": "X-Correlation-Id", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Hello, what can you do?\",\n  \"agentId\": \"default\",\n  \"stream\": false\n}"
            },
            "url": "{{baseUrl}}/api/bff/ai/chat"
          }
        },
        {
          "name": "Stream Message",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" },
              { "key": "X-Correlation-Id", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Tell me a story\",\n  \"agentId\": \"default\",\n  \"stream\": true\n}"
            },
            "url": "{{baseUrl}}/api/bff/ai/chat"
          }
        }
      ]
    },
    {
      "name": "Voice",
      "item": [
        {
          "name": "Process Intent",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"What's the weather today?\",\n  \"language\": \"en\"\n}"
            },
            "url": "{{baseUrl}}/api/bff/ai/voice/process-intent"
          }
        },
        {
          "name": "TTS Synthesis",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Welcome to Dakkah CityOS\",\n  \"voiceId\": \"default\",\n  \"language\": \"en\"\n}"
            },
            "url": "{{baseUrl}}/api/bff/ai/voice/speak"
          }
        },
        {
          "name": "STT Transcription",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"audioBase64\": \"<base64-encoded-audio>\"\n}"
            },
            "url": "{{baseUrl}}/api/bff/ai/voice/stt"
          }
        }
      ]
    },
    {
      "name": "Agents",
      "item": [
        {
          "name": "List Agents",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": "{{baseUrl}}/api/bff/ai/agents"
          }
        }
      ]
    },
    {
      "name": "Models",
      "item": [
        {
          "name": "List Models",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": "{{baseUrl}}/api/bff/ai/models"
          }
        }
      ]
    },
    {
      "name": "Conversations",
      "item": [
        {
          "name": "List Conversations",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/bff/ai/conversations?page=1&limit=20",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Tools",
      "item": [
        {
          "name": "Execute Tool",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tool\": \"cityos_weather\",\n  \"params\": {\"city\": \"Dakkah\"}\n}"
            },
            "url": "{{baseUrl}}/api/bff/ai/tools/execute"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "tenantId",
      "value": "default",
      "type": "string"
    }
  ]
}
