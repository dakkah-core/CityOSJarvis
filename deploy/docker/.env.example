# =============================================================================
# CityOSJarvis Docker Environment
# =============================================================================
# Copy to `.env` in this directory before `docker compose up`.
#
# For local development with external LLM APIs:
#   1. Set at least one provider API key below
#   2. Set CITYOSJARVIS_LLM_MODE=gateway
#   3. docker compose -f docker-compose.build.yml up -d
#
# For fully offline development:
#   1. Set CITYOSJARVIS_LLM_MODE=ollama
#   2. docker compose -f docker-compose.cityos.yml up -d
#   3. docker exec cityosjarvis ollama pull llama3.1
# =============================================================================

# -----------------------------------------------------------------------------
# Core Auth
# -----------------------------------------------------------------------------
OPENJARVIS_API_KEY=replace-with-generated-openjarvis-api-key

# -----------------------------------------------------------------------------
# Keycloak (optional — leave empty for local dev without auth)
# -----------------------------------------------------------------------------
KEYCLOAK_URL=
KEYCLOAK_REALM=cityos
KEYCLOAK_CLIENT_ID=cityosjarvis

# -----------------------------------------------------------------------------
# Database & Cache
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://jarvis:jarvis@postgres:5432/jarvis
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# LLM Routing Mode
#   gateway → Use LiteLLM proxy (requires provider API keys)
#   ollama  → Use Ollama directly (fully offline)
#   direct  → Use cloud APIs directly (bypass LiteLLM)
# -----------------------------------------------------------------------------
CITYOSJARVIS_LLM_MODE=gateway
CITYOSJARVIS_LLM_MODEL=gpt-4o-mini
OPENAI_API_BASE=http://litellm:4000
OLLAMA_URL=http://ollama:11434

# -----------------------------------------------------------------------------
# External LLM API Keys (at least one required for gateway/direct mode)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=                           # OpenAI platform key
ANTHROPIC_API_KEY=                        # Anthropic console key
AZURE_OPENAI_ENDPOINT=                    # https://{name}.openai.azure.com/
AZURE_OPENAI_KEY=                         # Azure OpenAI key
GEMINI_API_KEY=                           # Google AI Studio key
MOONSHOT_API_KEY=                         # Moonshot AI (Kimi) — https://platform.moonshot.cn/

# -----------------------------------------------------------------------------
# LiteLLM Proxy (when using docker-compose.build.yml)
# -----------------------------------------------------------------------------
PORT_LITELLM=4012
LITELLM_MASTER_KEY=replace-with-generated-litellm-master-key

# -----------------------------------------------------------------------------
# Voice / Speech
# -----------------------------------------------------------------------------
ENABLE_TTS=false                          # Set to true to enable Cartesia TTS
CARTESIA_API_KEY=                         # Required when ENABLE_TTS=true
WHISPER_MODEL=base                        # tiny/base/small/medium/large

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
CITYOS_LOG_LEVEL=INFO                     # DEBUG, INFO, WARNING, ERROR
LOKI_URL=http://loki:3100
OTEL_EXPORTER_OTLP_ENDPOINT=

# -----------------------------------------------------------------------------
# Ollama (local inference)
# -----------------------------------------------------------------------------
OLLAMA_IMAGE_TAG=latest
OLLAMA_GPU_COUNT=0                        # Set to 1 for NVIDIA GPU
OLLAMA_KEEP_ALIVE=5m
